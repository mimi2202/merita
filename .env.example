# ── Synapse RPC (bounty requirement: must be used in execution) ───────────────
OOBE_API_KEY=
SYNAPSE_RPC_URL=https://us-1-mainnet.oobeprotocol.ai?api_key=${OOBE_API_KEY}
SAP_AGENT_CLUSTER=mainnet

# ── Ace Data Cloud ───────────────────────────────────────────────────────────
ACEDATACLOUD_API_TOKEN=
ACE_FACILITATOR_URL=https://facilitator.acedata.cloud
# Base58 Solana private key that HOLDS USDC. This wallet pays Ace over x402.
# Keep it separate from the SAP agent wallets. Different money, different blast radius.
X402_SOLANA_PAYER_PRIVATE_KEY=

# ── Wiring ───────────────────────────────────────────────────────────────────
SIDECAR_URL=http://127.0.0.1:8787
SIDECAR_TOKEN=change-me
REFEREE_WALLET=secrets/referee-wallet.json
POSTER_WALLET=secrets/poster-wallet.json
